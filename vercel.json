{
    "version": 2,
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "docs.adan.sh"
                }
            ],
            "dest": "/pages/docs.html"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "install.adan.sh"
                }
            ],
            "dest": "/pages/install.html"
        },
        {
            "handle": "filesystem"
        }
    ]
}