{
    "version": 2,
    "outputDirectory": "public",
    "functions": {
        "api/run.ts": {
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "api.adan.sh"
                }
            ],
            "dest": "/api/$1"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "docs.adan.sh"
                }
            ],
            "dest": "/pages/docs/index.html"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "install.adan.sh"
                }
            ],
            "dest": "/pages/install/index.html"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "playground.adan.sh"
                }
            ],
            "dest": "/pages/playground/index.html"
        },
        {
            "handle": "filesystem"
        }
    ]
}