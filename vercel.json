{
    "version": 2,
    "outputDirectory": "public",
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "docs.adan.sh"
                }
            ],
            "destination": "/pages/docs.html"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "install.adan.sh"
                }
            ],
            "destination": "/pages/install.html"
        },
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "www.adan.sh"
                }
            ],
            "destination": "/index.html"
        }
    ]
}